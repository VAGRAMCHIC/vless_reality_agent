{
  "log": {
    "loglevel": "warning"
  },

  "api": {
    "services": ["HandlerService", "StatsService"],
    "tag": "api"
  },

  "inbounds": [
    {
      "tag": "test",

      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",

      "settings": {
        "clients": [],
        "decryption": "none"
      },

      "streamSettings": {
        "network": "tcp",
        "security": "reality",

        "realitySettings": {
          "show": false,
          "dest": "www.cloudflare.com:443",

          "serverNames": ["www.cloudflare.com"],

          "privateKey": "AAoepks9t7-N5w_vtJbQNSr06XWTHJuLc2tG0yoMNUQ",

          "shortIds": ["abcdef123456"]
        }
      }
    },

    {
      "tag": "api",
      "listen": "0.0.0.0",
      "port": 10085,
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1"
      }
    }
  ],

  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ],

  "routing": {
    "rules": [
      {
        "type": "field",
        "inboundTag": ["api"],
        "outboundTag": "direct"
      }
    ]
  }
}
